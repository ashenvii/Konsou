# ─────────────────────────────────────────────────────────────────────────────
# Konsou — environment variables
#
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit credentials.
#
# All VITE_* variables are compiled into the JS bundle at build time.
# The production binary has these baked in; end users never need a .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth — Desktop client ─────────────────────────────────────────────
# Created in Google Cloud Console → Credentials → OAuth client ID → Desktop app
# See: Konsou — Google OAuth Setup Guide.md → Part 1.4
VITE_GOOGLE_CLIENT_ID=YOUR_DESKTOP_CLIENT_ID.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET

# ── Google OAuth — Android client ─────────────────────────────────────────────
# Created in Google Cloud Console → Credentials → OAuth client ID → Android
# No client secret — Google verifies via package name + SHA-1 fingerprint.
# See: Konsou — Google OAuth Setup Guide.md → Part 3
VITE_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# ── Update checker ────────────────────────────────────────────────────────────
# GitHub repo in "owner/repo" format. The update checker fetches
# api.github.com/repos/{VITE_GITHUB_REPO}/releases/latest and compares
# to the bundled app version. Leave blank to disable.
VITE_GITHUB_REPO=your-username/konsou

# ── About page links ──────────────────────────────────────────────────────────
# Shown in Settings → About. Leave blank to keep the placeholder links.
VITE_KOFI_URL=https://ko-fi.com/your-page
VITE_GITHUB_URL=https://github.com/your-username/konsou

# ── Feature flags (all default to ON — only set these to disable) ─────────────
# VITE_FF_DRIVE_SYNC=false       # disable sync during dev/testing
# VITE_FF_SEQUEL_RADAR=false     # disable sequel detection
# VITE_FF_DISCOVER=false         # hide the Discover tab
