{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Konsou",
  "version": "0.1.0",
  "identifier": "com.konsou.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Konsou",
        "width": 1100,
        "height": 720,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCQkIxODczQTRDMUMxOUUKUldTZXdjR2tjeGk3bTdvUGx3OHAwTzZLR0UrOTFNdFlHTFVyRlhDU1Ntby9ObXhTRlJsQVRzMGcK",
      "endpoints": [
        "https://github.com/ashenvii/Konsou/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "mobile": [
        {
          "schemes": ["konsou"],
          "host": "callback"
        }
      ],
      "desktop": {
        "schemes": ["konsou"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "Offline-first anime tracker with sequel radar",
    "longDescription": "Konsou is an offline-first anime tracker for desktop and Android. No forced scoring, instant local list, and a sequel radar that tells you when a completed anime gets a new season.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
